# ============================================
# Unflat Mobile - Environment Variables
# ============================================
# Copy this file to .env and fill in values for local development.
# For EAS builds, set these as EAS Secrets (eas secret:create).

# Privy Authentication
# Get these from console.privy.io
PRIVY_APP_ID=your_privy_app_id
PRIVY_CLIENT_ID=your_privy_client_id

# Supabase (push notifications backend)
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Mixpanel Analytics (EU region)
# Get this from mixpanel.com → Project Settings → Token
MIXPANEL_TOKEN=your_mixpanel_project_token

# UXCam Session Recording (EU region)
# Get this from dashboard.uxcam.com → Settings → App Key
UXCAM_APP_KEY=your_uxcam_app_key

# Coinbase Developer Platform RPC
# Get this from portal.cdp.coinbase.com
CDP_RPC_URL=https://api.developer.coinbase.com/rpc/v1/base/YOUR_KEY

# EAS Project ID
# Get this from expo.dev project settings
EAS_PROJECT_ID=your_eas_project_id
